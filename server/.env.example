NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb://localhost:27017/focushub
# or, for Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/focushub

# Authentication (JWT access + rotating refresh tokens)
# Generate strong random values, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Optional, defaults to 12 if unset:
# BCRYPT_SALT_ROUNDS=12
